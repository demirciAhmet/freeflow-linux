[Unit]
Description=FreeFlow Linux voice dictation daemon
After=graphical-session.target
PartOf=graphical-session.target

[Service]
ExecStart=/home/YOUR_USERNAME/code/freeflow-linux/.venv/bin/python /home/YOUR_USERNAME/code/freeflow-linux/freeflow_linux.py
Restart=on-failure
RestartSec=3

# --- Wayland (Sway, Hyprland, KDE, GNOME) ---
# Adjust WAYLAND_DISPLAY if yours differs (check: echo $WAYLAND_DISPLAY)
Environment=XDG_SESSION_TYPE=wayland
Environment=WAYLAND_DISPLAY=wayland-1
Environment=XDG_RUNTIME_DIR=/run/user/1000
# Needed for compositor detection (gnome vs wlroots) and hyprctl:
Environment=XDG_CURRENT_DESKTOP=Hyprland

# --- X11 ---
# Environment=XDG_SESSION_TYPE=x11
# Environment=DISPLAY=:0

[Install]
WantedBy=graphical-session.target
